# ========================================
# MI Learning Platform - Environment Variables
# ========================================
# Copy this file to .env.local and fill in your values
# For Railway deployment, set these in the dashboard Variables section

# ========================================
# Supabase Configuration (REQUIRED)
# ========================================
# Get these from your Supabase project dashboard:
# Project Settings > API

# New recommended keys (publishable + secret):
# - sb_publishable_xxx: Safe for frontend/browsers
# - sb_secret_xxx: Backend only - NEVER expose publicly
#
# Legacy keys still work (anon + service_role):
# - anon key: JWT-based, can use during transition
# - service_role key: JWT-based, for backend

SUPABASE_URL=https://your-project-ref.supabase.co

# Frontend: Use publishable key (sb_publishable_xxx) - safe to expose
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-publishable-key

# Backend: Use secret key (sb_secret_xxx) - NEVER expose
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=sb_publishable_your-publishable-key
SUPABASE_SECRET_KEY=sb_secret_your-secret-key

# JWT secret (needed for auth token verification)
SUPABASE_JWT_SECRET=your-jwt-secret-from-supabase

# Legacy keys (still supported during transition)
# SUPABASE_SERVICE_ROLE_KEY=eyJhbG...your-service-role-key

# ========================================
# Application Settings (OPTIONAL - have defaults)
# ========================================
APP_NAME=MI Learning Platform
APP_VERSION=1.0.0
DEBUG=false
API_V1_PREFIX=/api/v1

# ========================================
# CORS Settings
# ========================================
# Comma-separated list of allowed origins
# Use "*" for development, specific domains for production
CORS_ORIGINS=*

# ========================================
# JWT Settings
# ========================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ========================================
# OpenAI Settings (Required for Chat Practice)
# ========================================
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key
# Model to use for chat practice (default: gpt-4.1-mini)
# You can also use gpt-4.1, gpt-4o, or other available models
OPENAI_MODEL=gpt-4.1-mini
